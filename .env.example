# Port configuration
PORT=5000

# Concurrency limit for background browser page instances
SCRAPER_CONCURRENCY=2 # 512MB host pe 2-3 se zyada mat rakhna, RAM monitor karke hi badhao

# Redis configuration (optional, falls back to memory cache if empty/offline)
REDIS_URL=redis://localhost:6379

# MongoDB configuration (optional, falls back to memory cache if empty/offline)
MONGO_URI=mongodb://localhost:27017/pincode_checker
